# Porta do servidor (padrão: 3001)
PORT=3001

# Segredo do JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=7d

# VAPID para notificações push — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@email.com

# Ambiente
NODE_ENV=development

# OpenAI (opcional)
# OPENAI_API_KEY=

# Em produção: URL do frontend (ex: https://medcontrol.vercel.app)
# ALLOWED_ORIGIN=https://seuapp.vercel.app
